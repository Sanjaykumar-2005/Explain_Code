# Get a key: https://aistudio.google.com/apikey — one line, no quotes (quotes are OK; the app strips them).
GEMINI_API_KEY=your_gemini_api_key_here
# Optional fallback if you use the name GOOGLE_API_KEY in other tools:
# GOOGLE_API_KEY=
# Must be a Gemini API model id (gemini-...), e.g. gemini-2.5-flash or gemini-1.5-flash. Not gemma-... for this app.
GEMINI_MODEL=gemini-2.5-flash
# Optional: comma-separated origins for CORS (defaults include localhost Next.js ports)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: Meta WhatsApp webhook verification (must match the verify token in Meta Developer Console)
# WHATSAPP_VERIFY_TOKEN=
